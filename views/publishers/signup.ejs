<!DOCTYPE html>

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Publisher Signup</title>
    <link rel="stylesheet" href="/publishers/signup.css">
</head>
<body>
    <div class="auth-page">
        <div class="auth-card">
            <h2>Publisher Signup</h2>


        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-error"><%= error %></div>
        <% } %>

        <% if (typeof success !== 'undefined' && success) { %>
            <div class="alert alert-success"><%= success %></div>
        <% } %>

        <form method="post" id="signupForm" action="/publisher/signup">

            <label for="username">Username</label>
            <input type="text" id="username" name="name" required />

            <label for="email">Email</label>
            <input type="email" id="email" name="email" required />

            <label for="password">Password</label>
            <input type="password" id="password" name="password" required />

            <button type="submit">Signup</button>
        </form>

        <p>Already registered? <a href="/publisher/login">Login</a></p>
    </div>


</body>
</html>
